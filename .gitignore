# All folders starting with _ are local.
_*/

# Compiled python files.
*.py[cod]
__pycache__/
*.pyc
*.pyo
*.pyd
# Visual Studio files.
/.vs
**/.vscode/ipch

# macOS files.
.DS_Store

# Generated license file.
PACKAGE-DEPS.yaml

# packman .user config
*.packman.xml.user

# kit user config
deps/**/user.toml

# vscode settings are copied and filled in from 'settings.json.template'
.vscode/settings.json

# PyCharm files.
/.idea/

# Linux in docker build $HOME dirs
/.nvidia-omniverse
/.local
/.cache

# Omniverse EULA breadcrumb
/.omniverse_eula_accepted.txt

# Streaming EventTrace
*.etli



/source/*
!/source/extensions/
!/source/extensions/omnicool.webapp/
!/source/extensions/omnicool.webapp/**

# Python bytecode cache
__pycache__/
*.pyc
*.pyo

# Flownex runtime-generated user settings and IO files
FlownexUser.json
Inputs.csv
Outputs.csv
StaticInputs.csv
