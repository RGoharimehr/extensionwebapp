# All folders starting with _ are local.
_*/

# Compiled python files.
*.py[cod]
__pycache__/

# Visual Studio files.
/.vs
**/.vscode/ipch

# macOS files.
.DS_Store

# Generated license file.
PACKAGE-DEPS.yaml

# packman .user config
*.packman.xml.user

# kit user config
deps/**/user.toml

# vscode settings are copied and filled in from 'settings.json.template'
.vscode/settings.json

# PyCharm files.
/.idea/

# Linux in docker build $HOME dirs
/.nvidia-omniverse
/.local
/.cache

# Omniverse EULA breadcrumb
/.omniverse_eula_accepted.txt

# Streaming EventTrace
*.etli

/source/*
!/source/extensions/
!/source/extensions/omnicool.webapp/
!/source/extensions/omnicool.webapp/**
# Exclude compiled Python bytecode even inside the tracked extension tree
source/extensions/omnicool.webapp/**/__pycache__/
source/extensions/omnicool.webapp/**/*.pyc
source/extensions/omnicool.webapp/**/*.pyo
